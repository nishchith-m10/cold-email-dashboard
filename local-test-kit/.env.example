# local-test-kit/.env.example
# Copy to .env and fill in real values

# Generated after first n8n login: Settings → API → Create API key
N8N_API_KEY=your-n8n-api-key-here

# Must match dashboard .env.local SIDECAR_AUTH_TOKEN
SIDECAR_AUTH_TOKEN=localdev-sidecar-token

# Must match dashboard .env.local SIDECAR_HANDSHAKE_SECRET
SIDECAR_HANDSHAKE_SECRET=localdev-handshake-secret

# URL the sidecar calls back to (your Next.js dev server)
DASHBOARD_CALLBACK_URL=http://host.docker.internal:3000
